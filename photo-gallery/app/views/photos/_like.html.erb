<%= turbo_frame_tag dom_id(photo, :like) do %>
  <% liked = photo.liked_by?(Current.user) %>
  <%= button_to photo_like_path(photo),
                method: liked ? :delete : :post,
                class: "like-button #{'liked' if liked}" do %>
    <%= image_tag(liked ? "star-fill.svg" : "star-line.svg", class: "icon", alt: liked ? "Unlike" : "Like") %>
    <span class="like-count"><%= photo.likes.size %></span>
  <% end %>
<% end %>
